@page "/"

<PageTitle>GitHub Actions Demo</PageTitle>

<h1>🚀 GitHub Actions Azure Web App Demo</h1>

<p>This application is automatically deployed using GitHub Actions.</p>

<hr/>

<ul>
    <li>GitHub Repository</li>
    <li>GitHub Actions</li>
    <li>Azure Web App</li>
</ul>

<button class="btn btn-primary" @onclick="ShowMessage">
    Verify Deployment
</button>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success mt-3">
        @message
    </div>
}

@code{

string message="";

void ShowMessage()
{
    message=$"Deployment Successful - {DateTime.Now}";
}

}